# 0G network. Use mainnet for live provider availability.
ZG_NETWORK=mainnet
ZG_RPC_URL=https://evmrpc.0g.ai

# Funded 0G wallet.
# WARNING: never commit the real .env.
PRIVATE_KEY=0xyourmainnetprivatekey

# Optional for current SDKs. Required only if your installed SDK cannot
# auto-detect mainnet contracts.
ZG_LEDGER_CA=
ZG_INFERENCE_CA=
ZG_FINE_TUNING_CA=

# Optional: pin a specific provider address. If unset, the script will pick
# the first live service whose model name matches MODEL_FILTER below.
PROVIDER_ADDRESS=

# Substring match against service.model to pick a provider.
MODEL_FILTER=qwen3.6-plus

# Initial main-account deposit (0G) if no Compute ledger exists.
INITIAL_DEPOSIT=3

# Optional provider sub-account transfer amount (0G). Set only when you want
# each inference run to top up the selected provider.
PROVIDER_TRANSFER_AMOUNT=0

# Optional storage override. Mainnet default is https://indexer-storage-turbo.0g.ai
ZG_INDEXER_URL=

# GhostProverRegistry address after deploying Chain/script/Deploy0G.s.sol.
REGISTRY_ADDRESS=
