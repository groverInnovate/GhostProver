# 0G testnet RPC
ZG_RPC_URL=https://evmrpc-testnet.0g.ai

# Funded testnet wallet (get tokens: https://faucet.0g.ai).
# WARNING: never commit the real .env.
PRIVATE_KEY=0xyourtestnetprivatekey

# Optional: pin a specific provider address. If unset, the script will pick
# the first live service whose model name matches MODEL_FILTER below.
PROVIDER_ADDRESS=

# Substring match against service.model to pick a provider.
MODEL_FILTER=qwen-2.5-7b-instruct

# Initial main-account deposit (0G) if balance is zero. Min recommended: 0.1.
INITIAL_DEPOSIT=0.1
