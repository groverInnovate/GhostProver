# 0G mainnet configuration for the live GhostProver receipt flow.
# Copy to .env and replace PRIVATE_KEY before running live paid operations.

ZG_NETWORK=mainnet
ZG_RPC_URL=https://evmrpc.0g.ai
ZG_INDEXER_URL=https://indexer-storage-turbo.0g.ai

PRIVATE_KEY=0xyourmainnetprivatekey

# Deployed GhostProverRegistry on 0G mainnet.
REGISTRY_ADDRESS=0x9595BD4e6b868C64001904EeF76d838D78604B6e

# 0G Compute provider selection.
MODEL_FILTER=qwen3.6-plus
PROVIDER_ADDRESS=

# Optional for SDKs that cannot auto-detect mainnet compute contracts.
ZG_LEDGER_CA=
ZG_INFERENCE_CA=
ZG_FINE_TUNING_CA=

# Funding behavior. Keep provider transfer at 0 unless intentionally topping up.
INITIAL_DEPOSIT=3
PROVIDER_TRANSFER_AMOUNT=0
